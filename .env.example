# LLM provider: gemini (workshop default) or ollama (free, local)
LLM_PROVIDER=gemini

# Ollama — install: https://ollama.com then run: ollama pull llama3.2:1b
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# Gemini — optional; get a free key at https://aistudio.google.com/apikey
# New AI Studio keys use the AQ. prefix (auth keys). Do not use Vertex keys.
# Set LLM_PROVIDER=gemini to use. gemini-2.0-flash was deprecated June 2026.
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
